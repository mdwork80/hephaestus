# Keep the build context minimal. Anything not listed as a COPY source in
# the Dockerfile should be excluded to speed builds and reduce the risk of
# shipping something unintended.

# Version control
.git
.gitignore
.gitattributes
.github/

# Secrets and local environment
.env
.env.*
!.env.example
*.key
*.pem
secrets/
.secrets.baseline

# Virtual environments (rebuilt in the builder stage)
.venv/
venv/
env/
ENV/

# Python build artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
*.egg

# Rust build artifacts (rebuilt in the builder stage)
target/

# Testing and linting caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
.hypothesis/

# Documentation and tests (not needed in the runtime image)
docs/
tests/
*.md
!README.md

# IDE and OS cruft
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Container files (avoid recursion if someone rebuilds from a prior output)
Dockerfile
Dockerfile.*
compose.yaml
compose.yml
docker-compose.yaml
docker-compose.yml
.dockerignore

# Infrastructure as Code (not needed in the application image)
infra/
bicep/
terraform/
*.tfstate
*.tfstate.backup

# SBOM outputs (generated per release, not packaged into images)
sbom.json
sbom.xml
bom.json
bom.xml
